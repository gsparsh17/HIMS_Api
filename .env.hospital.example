# ==============================================================
# ONE HOSPITAL / CLINIC DEPLOYMENT
# Provision this deployment from the MediQliq Central Admin.
# Never put ABDM bridge/client credentials on a hospital server.
# ==============================================================
NODE_ENV=production
APP_ROLE=HOSPITAL
PORT=5000
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER/FIRST_HOSPITAL_DB?retryWrites=true&w=majority
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_JWT_SECRET
FRONTEND_URL=https://first-hospital.mediqliq.com
CORS_ORIGINS=https://first-hospital.mediqliq.com
DISABLE_PERMISSION_CHECKS=false
ALLOW_PUBLIC_HOSPITAL_REGISTRATION=false

# Central MediQliq ABDM master connector
ABDM_ENABLED=true
ABDM_ENV=sandbox
ABDM_ENABLE_M1=true
ABDM_ENABLE_M2=true
ABDM_ENABLE_M3=false
ABDM_MASTER_URL=https://api.mediqliq.com

# Keep HFR Facility ID and the HIP/service ID separate even when they are equal.
ABDM_HFR_FACILITY_ID=INXXXXXXXXXX
ABDM_HIP_ID=INXXXXXXXXXX
ABDM_TENANT_CODE=FIRST_HOSPITAL
ABDM_CONNECTOR_KEY_ID=PASTE_KEY_ID_RETURNED_BY_CENTRAL_ADMIN
ABDM_CONNECTOR_SECRET=PASTE_ONE_TIME_SECRET_RETURNED_BY_CENTRAL_ADMIN
ABDM_INTERNAL_REQUEST_MAX_AGE_MS=300000
ABDM_INTERNAL_REPLAY_TTL_SECONDS=600

# User-initiated care-context linking requires HIP to send an OTP.
# Sandbox only: logs OTP to the hospital server console for controlled testing.
ABDM_LINK_OTP_TEST_MODE=false
ABDM_SMS_PROVIDER_URL=
ABDM_SMS_PROVIDER_BEARER_TOKEN=
ABDM_SMS_TEMPLATE_ID=ABDM_LINK_OTP
ABDM_SMS_TIMEOUT_MS=10000

# Existing ERP settings (examples only; add real values through a secret manager)
EMAIL_USER=
EMAIL_PASS=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
GEMINI_API_KEY=
