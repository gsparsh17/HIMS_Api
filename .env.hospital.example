# ==============================================================
# ONE HOSPITAL / CLINIC DEPLOYMENT
# Every client deployment has its own MongoDB and server.
# Do NOT put ABDM_CLIENT_SECRET on a hospital server.
# ==============================================================
NODE_ENV=production
APP_ROLE=HOSPITAL
PORT=5000
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER/FIRST_HOSPITAL_DB?retryWrites=true&w=majority
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_JWT_SECRET
FRONTEND_URL=https://first-hospital.mediqliq.com
CORS_ORIGINS=https://first-hospital.mediqliq.com
DISABLE_PERMISSION_CHECKS=false

# Central MediQliq ABDM master connector
ABDM_ENABLED=true
ABDM_ENV=sandbox
ABDM_ENABLE_M1=true
ABDM_ENABLE_M2=true
ABDM_ENABLE_M3=false
ABDM_MASTER_URL=https://api.mediqliq.com
ABDM_FACILITY_ID=INXXXXXXXXXX
ABDM_TENANT_CODE=FIRST_HOSPITAL
ABDM_CONNECTOR_KEY_ID=PASTE_KEY_ID_RETURNED_BY_MASTER_FACILITY_REGISTRATION
ABDM_CONNECTOR_SECRET=PASTE_ONE_TIME_SECRET_RETURNED_BY_MASTER_FACILITY_REGISTRATION

# User-initiated care-context linking requires HIP to send an OTP.
# SANDBOX ONLY: logs OTP to hospital server console for controlled testing.
ABDM_LINK_OTP_TEST_MODE=false
# Production-compatible option: connect your SMS provider through a small webhook adapter.
ABDM_SMS_PROVIDER_URL=
ABDM_SMS_PROVIDER_BEARER_TOKEN=
ABDM_SMS_TEMPLATE_ID=ABDM_LINK_OTP
ABDM_SMS_TIMEOUT_MS=10000

# Existing ERP settings (examples only; add your real values securely)
EMAIL_USER=
EMAIL_PASS=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
GEMINI_API_KEY=
