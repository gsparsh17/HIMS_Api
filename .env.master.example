# ==============================================================
# MEDIQLIQ CENTRAL ABDM MASTER / CONTROL PLANE
# Never commit real secrets. Use your secret manager in production.
# ==============================================================
NODE_ENV=production
APP_ROLE=ABDM_MASTER
PORT=5004
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER/mediqliq_abdm_master?retryWrites=true&w=majority

# Public HTTPS URL registered as the MediQliq ABDM bridge callback base.
ABDM_PUBLIC_BASE_URL=https://api.mediqliq.com
ABDM_ENV=sandbox
ABDM_CM_ID=sbx
ABDM_CLIENT_ID=REPLACE_WITH_ROTATED_SANDBOX_CLIENT_ID
ABDM_CLIENT_SECRET=REPLACE_WITH_ROTATED_SANDBOX_CLIENT_SECRET
ABDM_BRIDGE_ID=REPLACE_WITH_BRIDGE_ID
ABDM_SESSION_URL=https://dev.abdm.gov.in/api/hiecm/gateway/v3/sessions
ABDM_HIECM_BASE_URL=https://dev.abdm.gov.in/api/hiecm
ABDM_ABHA_BASE_URL=https://abhasbx.abdm.gov.in/abha/api

# Master operations API security. Generate long random values.
ABDM_MASTER_ADMIN_KEY=REPLACE_WITH_64_PLUS_CHAR_RANDOM_VALUE
ABDM_MASTER_ENCRYPTION_KEY=REPLACE_WITH_LONG_RANDOM_ENCRYPTION_SECRET

# Feature gates
ABDM_ENABLE_M1=true
ABDM_ENABLE_M2=true
ABDM_ENABLE_M3=false

# Callback hardening. Enable JWT verification only after confirming the current
# ABDM certificate endpoint and callback token behavior in your sandbox account.
ABDM_VERIFY_CALLBACK_JWT=false
# Optional comma-separated NAT IP allow-list supplied/confirmed by ABDM support.
ABDM_CALLBACK_ALLOWED_IPS=
ABDM_STORE_CALLBACK_PAYLOADS=false
ABDM_CALLBACK_RATE_LIMIT_PER_MINUTE=3000
ABDM_JOB_POLL_INTERVAL_MS=1000

# Hospital connector settings
ABDM_CONNECTOR_TIMEOUT_MS=15000
ABDM_INTERNAL_REQUEST_MAX_AGE_MS=300000

# M2 health-information encryption/data push is fail-closed by default.
# Configure a validated ABDM/NHA-compatible crypto adapter before enabling.
ABDM_DATA_PUSH_MODE=disabled
ABDM_CRYPTO_ADAPTER_URL=
ABDM_CRYPTO_ADAPTER_TOKEN=
ABDM_CRYPTO_ADAPTER_TIMEOUT_MS=20000
ABDM_DATA_PUSH_TIMEOUT_MS=30000

# Server hardening
CORS_ORIGINS=https://admin.mediqliq.com
TRUST_PROXY_HOPS=1
API_RATE_LIMIT_PER_MINUTE=600
JSON_BODY_LIMIT=10mb
